# Força XML a ser servido com o tipo correto
AddType application/xml .xml

# Ativa reescrita de URL (opcional, se você quiser usar URLs amigáveis no futuro)
<IfModule mod_rewrite.c>
  RewriteEngine On
  # Redireciona para HTTPS (opcional – descomente se quiser)
  # RewriteCond %{HTTPS} off
  # RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# Protege diretórios sensíveis
<FilesMatch "\.(htaccess|htpasswd|ini|log|conf|env)$">
  Order Allow,Deny
  Deny from all
</FilesMatch>
